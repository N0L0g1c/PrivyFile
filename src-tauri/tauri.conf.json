{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PrivyFile",
  "version": "0.1.0",
  "identifier": "com.vassdev.privyfile",
  "build": {
    "beforeDevCommand": "npm run fetch-exiftool && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run fetch-exiftool && npm run verify-exiftool && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PrivyFile",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "backgroundColor": "#0a0f1a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/win/": "binaries/win/",
      "binaries/linux/": "binaries/linux/",
      "binaries/macos/": "binaries/macos/"
    }
  }
}
